# AI Model API Keys (Required)

# Option 1: Azure OpenAI (Recommended for enterprise)
AZURE_OPENAI_GPT_API_KEY2=your-azure-api-key-here
AZURE_OPENAI_GPT_ENDPOINT2=your-azure-endpoint-here
AZURE_GPT_DEPLOYMENT_NAME2=your-deployment-name

# Option 2: Standard OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 3: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# GitHub Integration (Optional - for real PR creation)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, pull_request
# GITHUB_TOKEN=ghp_your-github-token-here

# GitHub Repository (Optional)
# Format: owner/repo
GITHUB_REPO=devopsconf/infrastructure-demo

# Demo Mode (true = mock PRs, false = real PRs)
DEMO_MODE=true

# OPA Policy Server (Optional)
# OPA_ENDPOINT=http://localhost:8181

# Logging
LOG_LEVEL=INFO
VERBOSE=true
